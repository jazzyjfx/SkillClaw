# SkillClaw Configuration

# LLM Provider — OpenRouter (Gemini 2.5 Flash)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENAI_API_KEY=sk-or-v1-your-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
EVOLVE_MODEL=xiaomi/mimo-v2.5

# Evolve Server
EVOLVE_ENGINE=workflow
EVOLVE_INTERVAL=43200
EVOLVE_STORAGE_BACKEND=local
EVOLVE_STORAGE_LOCAL_ROOT=/data/local-share
EVOLVE_GROUP_ID=openclaw-fleet
EVOLVE_LLM_MAX_TOKENS=5000
EVOLVE_LLM_TEMPERATURE=0.4

# Publishing — direct mode (no validation gate)
EVOLVE_PUBLISH_MODE=direct

# Session Exporter
OPENCLAW_GATEWAY=http://172.18.0.2:18789
SESSIONS_DIR=/data/local-share/default/sessions
LOOKBACK_MINUTES=60
EXPORTER_INTERVAL=3600

# Proxy/Dashboard (management only)
SKILLCLAW_PROXY_PORT=8080
SKILLCLAW_SKILLS_DIR=/data/skills
SKILLCLAW_SHARING_ENABLED=true
SKILLCLAW_SHARING_BACKEND=local
SKILLCLAW_SHARING_LOCAL_ROOT=/data/local-share
SKILLCLAW_SHARING_GROUP_ID=openclaw-fleet
SKILLCLAW_SHARING_USER_ALIAS=jazzy
LLM_CALL_DELAY=3

# Quality gates — enabled 2026-05-18
EVOLVE_USE_SKILL_VERIFIER=1
EVOLVE_REJECT_REWRITE=1
